---
const today = new Date();
---

<footer>
	<div class="inner">
		<span class="brand">클릭고트래블링</span>
		<nav class="links">
			<a href="/">홈</a>
			<a href="/blog">전체 글</a>
			<a href="/about">소개</a>
			<a href="/privacy">개인정보처리방침</a>
			<a href="/contact">문의하기</a>
			<a href="/rss.xml">RSS</a>
		</nav>
		<span class="copy">&copy; {today.getFullYear()} 클릭고트래블링</span>
	</div>
</footer>
<style>
	footer {
		border-top: 1px solid var(--border);
		margin-top: 4rem;
		background: var(--bg-sunken);
	}
	.inner {
		width: var(--maxw);
		max-width: calc(100% - 2rem);
		margin: 0 auto;
		padding: 2rem 0 3rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
	}
	.brand {
		font-family: var(--font-heading);
		font-weight: 800;
		color: var(--text);
	}
	.links { display: flex; gap: 1.2rem; flex-wrap: wrap; }
	.links a {
		color: var(--text-muted);
		font-weight: 600;
		font-size: 0.9rem;
	}
	.links a:hover { color: var(--accent); }
	@media (max-width: 720px) {
		/* 모바일 터치 타깃 확보 */
		.links { gap: 0.2rem 0.8rem; }
		.links a { display: inline-flex; align-items: center; min-height: 44px; }
		.inner { padding: 1.5rem 0 2rem; }
	}
	.copy { color: var(--text-dim); font-size: 0.85rem; }
</style>
