---
import { SITE_TITLE } from '../consts';
import { CATEGORIES } from '../categories';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="brand">
			<span class="logo" aria-hidden="true">
				<svg viewBox="0 0 40 40" width="30" height="30">
					<circle cx="20" cy="20" r="17.5" fill="none" stroke="var(--lacquer)" stroke-width="1.6" stroke-dasharray="2.5 3.5" />
					<circle cx="20" cy="20" r="12" fill="none" stroke="var(--lacquer)" stroke-width="1" />
					<path d="M20 13.5l1.9 4.3 4.6.4-3.5 3 1 4.5-4-2.4-4 2.4 1-4.5-3.5-3 4.6-.4z" fill="var(--lacquer)" />
				</svg>
			</span>
			<span class="brand-name">{SITE_TITLE}</span>
		</a>
		<div class="internal-links">
			<HeaderLink href="/">홈</HeaderLink>
			{
				CATEGORIES.map((cat) => (
					<HeaderLink href={`/category/${cat.slug}/`}>{cat.emoji} {cat.label}</HeaderLink>
				))
			}
			<HeaderLink href="/blog">전체 글</HeaderLink>
			<HeaderLink href="/vietnam-realestate/">🏙️ 부동산</HeaderLink>
			<HeaderLink href="/about">소개</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: rgba(243, 237, 220, 0.88);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border);
	}
	nav {
		width: var(--maxw);
		max-width: calc(100% - 2.5em);
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem 1rem;
		flex-wrap: wrap;
		padding: 0.9rem 0;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 0.5em;
		text-decoration: none;
	}
	.logo {
		display: inline-flex;
		line-height: 1;
	}
	.brand-name {
		font-family: var(--font-heading);
		font-weight: 900;
		font-size: 1.25rem;
		letter-spacing: -0.01em;
		color: var(--text);
	}
	.brand:hover .brand-name {
		color: var(--lacquer);
	}
	.internal-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35em;
	}
	.internal-links :global(a) {
		padding: 0.5em 0.9em;
		color: var(--text-muted);
		border-radius: 999px;
		font-weight: 600;
		font-size: 0.95rem;
		text-decoration: none;
		transition: color 0.15s ease, background 0.15s ease;
	}
	.internal-links :global(a:hover) {
		color: var(--text);
		background: var(--bg-elev-2);
	}
	.internal-links :global(a.active) {
		color: var(--lacquer);
		background: rgba(178, 58, 33, 0.09);
	}
	@media (max-width: 520px) {
		.brand-name { font-size: 1.05rem; }
		.internal-links :global(a) { padding: 0.4em 0.6em; font-size: 0.88rem; }
	}
</style>
