---
import { SITE_TITLE } from '../consts';
import { CATEGORIES } from '../categories';
import HeaderLink from './HeaderLink.astro';
---

<a href="#main" class="skip-link">본문 바로가기</a>
<header>
	<div class="bar">
		<a href="/" class="brand" aria-label={`${SITE_TITLE} 홈`}>
			<svg class="mark" viewBox="0 0 24 24" width="26" height="26" aria-hidden="true">
				<path
					d="M2 12.5l19.5-8.2a.6.6 0 01.8.8L14.1 24a.6.6 0 01-1.1-.1l-2.3-7.2-7.6-2.9a.6.6 0 01-.1-1.3z"
					fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"
				/>
			</svg>
			<span class="brand-name">{SITE_TITLE}</span>
		</a>
		<nav class="nav" aria-label="주요 메뉴">
			<div class="nav-scroll">
				{
					CATEGORIES.map((cat) => (
						<HeaderLink href={`/category/${cat.slug}/`}>{cat.label}</HeaderLink>
					))
				}
				<HeaderLink href="/hochiminh-course/">호치민 코스</HeaderLink>
				<HeaderLink href="/vietnam-realestate/">부동산 시세</HeaderLink>
				<HeaderLink href="/blog">전체 글</HeaderLink>
				<HeaderLink href="/about">소개</HeaderLink>
			</div>
		</nav>
	</div>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: rgba(255, 255, 255, 0.94);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--border);
	}
	.bar {
		width: var(--maxw);
		max-width: calc(100% - 2rem);
		margin: 0 auto;
		display: flex;
		align-items: center;
		gap: var(--s5);
		min-height: 60px;
	}
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.45em;
		color: var(--text);
		flex-shrink: 0;
	}
	.mark { color: var(--accent); }
	.brand-name {
		font-family: var(--font-heading);
		font-weight: 800;
		font-size: 1.12rem;
		letter-spacing: -0.03em;
	}
	.brand:hover { color: var(--accent); }

	.nav { min-width: 0; flex: 1; }
	.nav-scroll {
		display: flex;
		align-items: center;
		gap: 0.15rem;
		overflow-x: auto;
		scrollbar-width: none;
		-webkit-overflow-scrolling: touch;
	}
	.nav-scroll::-webkit-scrollbar { display: none; }

	.nav-scroll :global(a) {
		display: inline-flex;
		align-items: center;
		white-space: nowrap;
		padding: 0.5em 0.75em;
		min-height: 40px;
		color: var(--text-muted);
		border-radius: var(--radius-sm);
		font-weight: 600;
		font-size: 0.94rem;
		transition: color 0.15s ease, background 0.15s ease;
	}
	.nav-scroll :global(a:hover) { color: var(--text); background: var(--bg-elev-2); }
	.nav-scroll :global(a.active) {
		color: var(--accent-dim);
		background: var(--accent-soft);
	}

	@media (max-width: 860px) {
		.bar {
			flex-direction: column;
			align-items: stretch;
			gap: 0;
			padding: 0.55rem 0 0;
		}
		.brand { align-self: flex-start; padding-bottom: 0.4rem; }
		/* 모바일에선 카테고리가 가로 스크롤 — 화면 끝까지 흘려보낸다 */
		.nav-scroll {
			margin: 0 -1rem;
			padding: 0 1rem 0.5rem;
		}
		/* 모바일 터치 타깃 44px 확보 */
		.nav-scroll :global(a) { font-size: 0.9rem; padding: 0.55em 0.7em; min-height: 44px; }
		.brand { min-height: 44px; }
	}
</style>
