---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import { CATEGORIES, categoryOf } from '../categories';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const lead = posts[0];
const rest = posts.slice(1, 13);

// 카테고리별 글 수 — 얼마나 있는지 보여주면 탐색으로 이어진다
const catCounts = CATEGORIES.map((c) => ({ ...c, count: c.posts.length }));
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main id="main">
			{/* 인트로 — 한 줄. 첫 화면을 잡아먹지 않는다 */}
			<section class="intro">
				<h1>호치민·다낭 여행, 현지에서 직접 씁니다</h1>
				<p>{SITE_DESCRIPTION}</p>
			</section>

			{/* 최신 글 — 가로형 리드 카드 */}
			{
				lead && (
					<article class="lead">
						<a href={`/${lead.id}/`} class="lead-link">
							{lead.data.heroImage && (
								<div class="lead-media">
									<Image
										src={lead.data.heroImage}
										width={880}
										height={495}
										alt=""
										loading="eager"
									/>
								</div>
							)}
							<div class="lead-body">
								<span class="kicker">
									최신 글
									{categoryOf(lead.id) && <> · {categoryOf(lead.id)!.label}</>}
								</span>
								<h2>{lead.data.title}</h2>
								<p>{lead.data.description}</p>
								<span class="meta"><FormattedDate date={lead.data.pubDate} /></span>
							</div>
						</a>
					</article>
				)
			}

			{/* 애드센스 슬롯 — 재승인 후 이 안에 코드만 삽입 */}
			<div class="ad-slot" data-ad-slot="home-top"></div>

			{/* 주제별 찾기 */}
			<section class="browse" aria-labelledby="browse-h">
				<h2 id="browse-h" class="section-title">주제별로 찾기</h2>
				<ul class="browse-list">
					{
						catCounts.map((c) => (
							<li>
								<a href={`/category/${c.slug}/`} class="browse-item">
									<span class="browse-label">{c.label}</span>
									<span class="browse-count">{c.count}</span>
								</a>
							</li>
						))
					}
					<li>
						<a href="/vietnam-realestate/" class="browse-item">
							<span class="browse-label">부동산 시세</span>
							<span class="browse-count browse-count--new">지도</span>
						</a>
					</li>
				</ul>
			</section>

			{/* 글 목록 */}
			{
				rest.length > 0 && (
					<section aria-labelledby="latest-h">
						<div class="section-head">
							<h2 id="latest-h" class="section-title">최근 글</h2>
							<a href="/blog" class="more">전체 보기 →</a>
						</div>
						<ul class="grid">
							{rest.map((post, i) => {
								const cat = categoryOf(post.id);
								return (
									<li>
										<a href={`/${post.id}/`} class="card">
											{post.data.heroImage && (
												<div class="card-media">
													<Image
														src={post.data.heroImage}
														width={560}
														height={315}
														alt=""
														loading={i < 3 ? 'eager' : 'lazy'}
													/>
												</div>
											)}
											<div class="card-body">
												{cat && <span class="card-cat">{cat.label}</span>}
												<h3>{post.data.title}</h3>
												<p>{post.data.description}</p>
												<span class="meta"><FormattedDate date={post.data.pubDate} /></span>
											</div>
										</a>
									</li>
								);
							})}
						</ul>
					</section>
				)
			}

			<div class="ad-slot" data-ad-slot="home-bottom"></div>
		</main>
		<Footer />
	</body>
</html>

<style>
	/* ── 인트로 ─────────────────────────── */
	.intro {
		padding: var(--s2) 0 var(--s5);
		border-bottom: 1px solid var(--border);
		margin-bottom: var(--s6);
	}
	.intro h1 {
		font-size: clamp(1.6rem, 4vw, 2.2rem);
		margin: 0 0 0.35rem;
	}
	.intro p {
		color: var(--text-muted);
		margin: 0;
		max-width: 60ch;
		font-size: 1rem;
	}

	/* ── 리드 카드 ───────────────────────── */
	.lead { margin-bottom: var(--s6); }
	.lead-link {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
		gap: var(--s6);
		align-items: center;
		color: inherit;
	}
	.lead-media {
		border-radius: var(--radius);
		overflow: hidden;
		background: var(--bg-elev-2);
		aspect-ratio: 16 / 9;   /* 자리를 미리 잡아 레이아웃 밀림(CLS) 방지 */
	}
	.lead-media img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		transition: transform 0.4s ease;
	}
	.lead-link:hover .lead-media img { transform: scale(1.03); }
	.kicker {
		display: inline-block;
		font-size: 0.82rem;
		font-weight: 700;
		color: var(--accent-dim);
		margin-bottom: 0.6rem;
	}
	.lead-body h2 {
		font-size: clamp(1.35rem, 2.6vw, 1.9rem);
		margin: 0 0 0.5rem;
	}
	.lead-link:hover h2 { color: var(--accent-dim); }
	.lead-body p {
		color: var(--text-muted);
		margin: 0 0 0.8rem;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.meta {
		display: block;
		font-size: 0.85rem;
		color: var(--text-dim);
		font-variant-numeric: tabular-nums;
	}

	/* ── 주제별 찾기 ─────────────────────── */
	.browse { margin-bottom: var(--s7); }
	.section-title {
		font-size: 1.15rem;
		font-weight: 800;
		margin: 0 0 var(--s4);
	}
	.browse-list {
		display: flex;
		flex-wrap: wrap;
		gap: var(--s2);
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.browse-item {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		min-height: 44px;
		padding: 0.5em 1em;
		border: 1px solid var(--border);
		border-radius: 999px;
		color: var(--text);
		font-weight: 600;
		background: #fff;
		transition: border-color 0.15s ease, background 0.15s ease;
	}
	.browse-item:hover {
		border-color: var(--accent-border);
		background: var(--accent-soft);
		color: var(--accent-dim);
	}
	.browse-count {
		font-size: 0.8rem;
		font-weight: 700;
		color: var(--text-dim);
		background: var(--bg-elev-2);
		border-radius: 999px;
		padding: 0.1em 0.55em;
		font-variant-numeric: tabular-nums;
	}
	.browse-count--new { color: var(--accent-dim); background: var(--accent-soft); }

	/* ── 목록 ───────────────────────────── */
	.section-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: var(--s4);
		margin-bottom: var(--s4);
	}
	.more {
		font-weight: 600;
		font-size: 0.92rem;
		white-space: nowrap;
		display: inline-flex;
		align-items: center;
		min-height: 44px;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: var(--s5);
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.card {
		display: flex;
		flex-direction: column;
		height: 100%;
		color: inherit;
	}
	.card-media {
		border-radius: var(--radius-sm);
		overflow: hidden;
		background: var(--bg-elev-2);
		aspect-ratio: 16 / 9;
		margin-bottom: 0.85rem;
	}
	.card-media img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		transition: transform 0.4s ease;
	}
	.card:hover .card-media img { transform: scale(1.04); }
	.card-body { display: flex; flex-direction: column; flex: 1; }
	.card-cat {
		font-size: 0.78rem;
		font-weight: 700;
		color: var(--accent-dim);
		margin-bottom: 0.3rem;
	}
	.card h3 {
		font-size: 1.05rem;
		line-height: 1.45;
		margin: 0 0 0.4rem;
	}
	.card:hover h3 { color: var(--accent-dim); }
	.card p {
		color: var(--text-muted);
		font-size: 0.93rem;
		line-height: 1.6;
		margin: 0 0 0.7rem;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.card .meta { margin-top: auto; }

	/* ── 반응형 ─────────────────────────── */
	@media (max-width: 900px) {
		.lead-link { grid-template-columns: 1fr; gap: var(--s4); }
		.grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
	}
	@media (max-width: 560px) {
		.grid { grid-template-columns: 1fr; gap: var(--s5); }
		.intro { padding-top: 0; }
		/* 모바일은 가로형 카드 — 한 화면에 더 많은 글이 들어간다 */
		.card { flex-direction: row; gap: var(--s3); align-items: flex-start; }
		.card-media { flex: 0 0 132px; margin-bottom: 0; }
		.card h3 { font-size: 0.98rem; }
		.card p { display: none; }
	}
</style>
