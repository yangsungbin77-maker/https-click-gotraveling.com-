---
import Layout from '../layouts/BlogPost.astro';
import aptData from '../data/apartments.json';

const rate = aptData.rate_krw_per_usd;
const vnd = aptData.rate_vnd_per_usd;
const won = (usd: number) => Math.round((usd * rate) / 10000); // 만원
const mildong = (usd: number) => Math.round((usd * vnd) / 1000000); // 백만동
const gradeColor: Record<string, string> = { '최상': '#e0564f', '상': '#e8a838', '중': '#3b82f6', '하': '#8b98a9' };
const rentStr = (a: any) => a.rent_2br_usd ? `$${a.rent_2br_usd[0]}~${a.rent_2br_usd[1]}` : '분양 문의';
---

<Layout
	title="호치민 아파트 시세·분양 지도 — 2룸·3룸 월세와 분양가 원화 환산"
	description="호치민 교민 인기 아파트와 신규 분양 단지를 지도에서 한눈에. 푸미흥·타오디엔·빈홈즈·9군 그랜드파크·투티엠 분양까지 2룸·3룸 월세와 분양가를 한국 돈으로 환산해 정리했습니다. 정보 제공 목적, 시점 기준."
	pubDate={new Date('July 21 2026')}
>
	<p>
		호치민에서 <strong>어디에 어떤 아파트가 얼마인지</strong>, 그리고 <strong>지금 분양 중인 단지</strong>는
		어딘지 지도로 한눈에 보고 싶으시죠? 그래서 교민이 많이 사는 아파트부터 9군 그랜드파크·투티엠 신규 분양까지
		지도에 모으고, 2룸·3룸 월세와 분양가를 <strong>한국 돈으로 환산</strong>해 정리했어요. 핀을 눌러보세요.
	</p>

	<img src="/realty/hero.webp" alt="호치민 아파트 스카이라인 시세 지도" width="900" height="604" style="width:100%;border-radius:14px;margin:1rem 0" />

	<div class="cg-box cg-warn"><span class="cg-title">⚠️ 먼저 알아두세요</span><p>정보 제공 목적이며 중개·투자자문이 아닙니다. 가격은 <b>{aptData.updated} 시점의 참고 범위</b>로, 층·전망·가구·계약조건에 따라 크게 달라집니다. 환율 $1≈{rate.toLocaleString()}원 기준(변동). 실제 계약은 현지 공식정보·전문가 확인이 필요합니다.</p></div>

	<div style="display:flex;gap:8px;flex-wrap:wrap;margin:0.6rem 0;align-items:center">
		<button class="apt-filter is-on" data-f="all">전체</button>
		<button class="apt-filter" data-f="korean">🇰🇷 교민 살기 좋은 곳</button>
		<button class="apt-filter" data-f="sale">🏗️ 분양 중</button>
		<span style="margin-left:auto;font-size:.8rem;color:var(--text-dim)">🔴최상 🟠상 🔵중 ⚪하 · 점선=분양중</span>
	</div>

	<div id="apt-map" style="height:480px;width:100%;border-radius:14px;overflow:hidden;border:1px solid var(--border);z-index:0"></div>

	<h2>교민 인기 아파트·분양 시세 한눈에 보기</h2>
	<p>2룸·3룸 <strong>월세</strong>와 <strong>분양가(㎡당)</strong> 기준입니다(시점·단지별 편차 큼). 한국 돈은 환율 환산 참고값이에요.</p>

	<table>
		<thead><tr><th>단지</th><th>지역</th><th>2룸 월세</th><th>3룸 월세</th><th>분양가(㎡당)</th><th>상태</th></tr></thead>
		<tbody>
			{aptData.apartments.map((a) => (
				<tr>
					<td><strong>{a.name_kr}</strong></td>
					<td>{a.district_kr}</td>
					<td>{a.rent_2br_usd ? (<span>${a.rent_2br_usd[0]}~{a.rent_2br_usd[1]}<br/><span style="color:var(--text-dim);font-size:.85em">약 {won(a.rent_2br_usd[0])}~{won(a.rent_2br_usd[1])}만원</span></span>) : '—'}</td>
					<td>{a.rent_3br_usd ? (<span>${a.rent_3br_usd[0]}~{a.rent_3br_usd[1]}<br/><span style="color:var(--text-dim);font-size:.85em">약 {won(a.rent_3br_usd[0])}~{won(a.rent_3br_usd[1])}만원</span></span>) : '—'}</td>
					<td>{a.sale_per_m2_usd ? (<span>${a.sale_per_m2_usd[0].toLocaleString()}~{a.sale_per_m2_usd[1].toLocaleString()}<br/><span style="color:var(--text-dim);font-size:.85em">약 {won(a.sale_per_m2_usd[0]).toLocaleString()}만~{won(a.sale_per_m2_usd[1]).toLocaleString()}만원</span></span>) : '—'}</td>
					<td>{a.status === '분양중' ? '🏗️ 분양중' : '완공'} · 교민 {a.korean}</td>
				</tr>
			))}
		</tbody>
	</table>

	<h2>단지 둘러보기</h2>
	<p>단지별 분위기와 핵심 가격을 카드로 정리했어요. 이미지는 <strong>분위기 참고용</strong>입니다(실제 건물 사진 아님).</p>

	<div class="apt-grid">
		{aptData.apartments.map((a) => (
			<div class="apt-card">
				<img src={a.img} alt={`${a.name_kr} ${a.district_kr} 호치민 아파트`} width="900" height="672" loading="lazy" />
				<div class="apt-card-b">
					<div class="apt-card-t">
						<strong>{a.name_kr}</strong>
						{a.status === '분양중' && <span class="apt-badge">🏗️ 분양중</span>}
					</div>
					<div class="apt-card-d">{a.district_kr} · 교민 {a.korean}</div>
					<div class="apt-card-p">
						{a.rent_2br_usd
							? <span>2룸 월 약 {won(a.rent_2br_usd[0])}만~{won(a.rent_2br_usd[1])}만원</span>
							: <span>임대 정보 없음</span>}
					</div>
					{a.sale_per_m2_usd && (
						<div class="apt-card-s">분양가 ㎡당 약 {won(a.sale_per_m2_usd[0]).toLocaleString()}만~{won(a.sale_per_m2_usd[1]).toLocaleString()}만원</div>
					)}
					<div class="apt-card-g">{a.tags.slice(0, 3).map((t) => <span>#{t}</span>)}</div>
				</div>
			</div>
		))}
	</div>

	<h2>9군·투득 신도시는 어떤가요?</h2>
	<p>
		결론부터 말하면요, <strong>9군(현 투득시)의 빈홈즈 그랜드파크</strong>가 요즘 분양 물량이 가장 많은
		초대형 신도시예요. 271ha 부지에 자체 몰·학교·중앙공원이 있고, 도심보다 저렴해서 가성비를 원하는
		분들이 많이 봅니다. 다만 도심(1·2·7군)보다 이동 거리가 있어 <strong>메트로 개통 여부</strong>가 관건이에요.
	</p>

	<h2>지금 분양 중인 단지는 어디인가요?</h2>
	<p>
		신규 분양은 <strong>투득시(옛 2·9군)와 투티엠</strong>에 몰려 있습니다. 대표적으로 Masterise의
		<strong>더 글로벌 시티</strong>, 투티엠 최고가 <strong>메트로폴</strong>, 강변 프리미엄
		<strong>엠파이어시티</strong>가 분양 중이고, 서부(떤푸·빈떤)의 셀라돈·미즈키파크는 상대적 가성비 분양이에요.
	</p>
	<div class="cg-box cg-tip"><span class="cg-title">💡 분양가 감 잡기 (원화)</span><p>호치민 2026년 <b>1차(분양) 평균이 ㎡당 약 $7,200 = 약 994만원</b>이고, 투득 프리미엄은 ㎡당 $15,000(약 2,070만원)을 넘기도 해요. 가성비 신도시(그랜드파크·미즈키)는 ㎡당 $1,600~2,600(약 221만~359만원)으로 훨씬 낮습니다. <b>84㎡ 기준</b>으로 보면 가성비 단지가 약 1억9천만~3억원, 평균가 단지는 약 8억원대가 됩니다.</p></div>

	<h2>교민들이 살기 좋은 아파트는 어디인가요?</h2>
	<p>
		<strong>7군 푸미흥</strong>이 한인타운입니다. 한국국제학교·한국병원·한인마트가 모여 정착 편의가 가장
		좋아요. <strong>2군 타오디엔</strong>은 외국인·서양인 밀집 지역, <strong>빈타인(빈홈즈 센트럴파크)</strong>은
		랜드마크81을 낀 강변 신축으로 교민이 많습니다. 지도의 <b>🇰🇷 교민 살기 좋은 곳</b> 버튼으로 걸러 볼 수 있어요.
	</p>

	<h2>계약할 때 알아둘 점</h2>
	<p>
		호치민 월세는 <strong>보증금이 보통 2개월치</strong>이고, 전기세는 따로 내는 게 일반적이에요(에어컨
		많이 쓰면 월 $50~$100). 관리비는 단지마다 다르고 인터넷은 보통 포함됩니다. 외국인은 단지별 분양 비율
		제한 등 규정이 있으니, 특히 분양·매매는 현지 확인이 꼭 필요해요.
	</p>
	<div class="cg-box cg-danger"><span class="cg-title">🚨 꼭 확인</span><p>이 지도의 가격은 참고용입니다. 실제 매물·분양·계약은 반드시 현지 공식 정보와 자격 있는 전문가를 통해 확인하세요. 특정 단지 매매·분양·투자를 권유하지 않습니다.</p></div>

	<h2>자주 묻는 질문 (FAQ)</h2>
	<p><strong>Q. 호치민에서 교민이 가장 많이 사는 아파트 지역은 어디인가요?</strong> 7군 푸미흥이 대표 한인타운입니다. 한국국제학교·한국병원·한인마트가 모여 있어요. 그다음으로 2군 타오디엔, 빈타인(빈홈즈 센트럴파크)에 교민이 많습니다.</p>
	<p><strong>Q. 9군(투득) 빈홈즈 그랜드파크 월세는 얼마인가요?</strong> 2룸 기준 대략 월 $280~880(약 39만~121만원)로 도심보다 저렴한 편입니다. 초대형 신도시라 분양 물량도 많습니다. 시점 기준입니다.</p>
	<p><strong>Q. 호치민 신규 분양가는 ㎡당 얼마인가요?</strong> 2026년 1차(분양) 평균이 ㎡당 약 $7,200, 한국 돈으로 약 994만원입니다. 투득 프리미엄은 ㎡당 약 2,070만원을 넘기도 하고, 가성비 신도시는 약 221만~359만원 수준이에요. 84㎡ 기준이면 가성비 단지 약 1억9천만~3억원, 평균가 단지 약 8억원대입니다.</p>
	<p><strong>Q. 호치민 2룸 아파트 월세 범위는요?</strong> 교민 인기 단지 기준 대략 월 $280~2,800(약 39만~386만원)로 폭이 넓습니다. 외곽·구축은 낮고, 투티엠 프리미엄은 높습니다.</p>

	<p>
		호치민 생활이 처음이라면 <a href="/vietnam-restaurant-finding/">현지 맛집 찾는 법</a>,
		<a href="/ho-chi-minh-map-travel-course/">호치민 지도·코스</a>,
		<a href="/travel-vietnamese-phrases/">여행 베트남어 표현</a>도 함께 보면 정착이 한결 수월할 거예요.
	</p>

	<h2>참고 출처</h2>
	<p>
		시세·분양가는 <a href="https://vietnamrenty.com/market-report/hcmc-apartment-rental-market-report-h1-2026/" target="_blank" rel="noopener">VietnamRenty 임대시장 리포트</a>,
		<a href="https://www.cushmanwakefield.com/en/vietnam/insights/ho-chi-minh-city-marketbeat/residential-marketbeat" target="_blank" rel="noopener">Cushman &amp; Wakefield HCMC 리포트</a>,
		<a href="https://bambooroutes.com/blogs/news/ho-chi-minh-city-housing-prices" target="_blank" rel="noopener">Bamboo Routes</a>,
		<a href="https://www.vinahanin.com/index.php?mid=apt" target="_blank" rel="noopener">비나한인</a> 등 공개 자료를 시점 기준으로 정리했습니다. 값은 변동되니 최신 정보는 각 출처에서 확인하세요.
	</p>
</Layout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script define:vars={{ apts: aptData.apartments, rate, vnd, colors: gradeColor }} is:inline>
	(function init() {
		if (typeof L === 'undefined') { return setTimeout(init, 100); }
		var map = L.map('apt-map', { scrollWheelZoom: false }).setView([10.79, 106.74], 11);
		L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
			maxZoom: 18, attribution: '© OpenStreetMap'
		}).addTo(map);
		var won = function (u) { return Math.round((u * rate) / 10000); };
		var mildong = function (u) { return Math.round((u * vnd) / 1000000); };
		var markers = [];
		apts.forEach(function (a) {
			var color = colors[a.korean] || '#3b82f6';
			var isSale = a.status === '분양중';
			var m = L.circleMarker([a.lat, a.lng], {
				radius: 11, color: isSale ? '#0f6e63' : '#fff', weight: isSale ? 3 : 2,
				dashArray: isSale ? '4 3' : null, fillColor: color, fillOpacity: 0.95
			}).addTo(map);
			var html = '<div style="min-width:200px">'
				+ '<img src="' + a.img + '" alt="' + a.name_kr + '" style="width:100%;height:88px;object-fit:cover;border-radius:8px;margin-bottom:6px">'
				+ '<b style="font-size:14px">' + a.name_kr + '</b>'
				+ (isSale ? ' <span style="color:#0f6e63;font-size:11px;font-weight:700">🏗️분양중</span>' : '') + '<br>'
				+ '<span style="color:#666">' + a.district_kr + ' · 교민 ' + a.korean + '</span><hr style="margin:6px 0">';
			if (a.rent_2br_usd) {
				html += '<b>2룸</b> $' + a.rent_2br_usd[0] + '~' + a.rent_2br_usd[1] + ' <span style="color:#888">(약 ' + won(a.rent_2br_usd[0]) + '~' + won(a.rent_2br_usd[1]) + '만원)</span><br>'
					+ '<b>3룸</b> $' + a.rent_3br_usd[0] + '~' + a.rent_3br_usd[1] + ' <span style="color:#888">(약 ' + won(a.rent_3br_usd[0]) + '~' + won(a.rent_3br_usd[1]) + '만원)</span><br>';
			}
			if (a.sale_per_m2_usd) {
				html += '<b style="color:#0f6e63">분양가</b> ㎡당 $' + a.sale_per_m2_usd[0].toLocaleString() + '~' + a.sale_per_m2_usd[1].toLocaleString()
					+ ' <span style="color:#888">(약 ' + won(a.sale_per_m2_usd[0]).toLocaleString() + '만~' + won(a.sale_per_m2_usd[1]).toLocaleString() + '만원)</span><br>'
					+ '<span style="color:#0f6e63;font-size:11.5px">84㎡ 환산 약 ' + Math.round(won(a.sale_per_m2_usd[0]) * 84 / 10000) + '억~' + Math.round(won(a.sale_per_m2_usd[1]) * 84 / 10000) + '억원</span><br>';
			}
			html += '<span style="color:#555;font-size:12px">' + a.desc + '</span></div>';
			m.bindPopup(html);
			m._korean = a.korean; m._sale = isSale;
			markers.push(m);
		});
		var btns = document.querySelectorAll('.apt-filter');
		btns.forEach(function (b) {
			b.addEventListener('click', function () {
				btns.forEach(function (x) { x.classList.remove('is-on'); });
				b.classList.add('is-on');
				var f = b.getAttribute('data-f');
				markers.forEach(function (m) {
					var show = (f === 'all') || (f === 'korean' && (m._korean === '최상' || m._korean === '상')) || (f === 'sale' && m._sale);
					if (show) { m.addTo(map); } else { map.removeLayer(m); }
				});
			});
		});
	})();
</script>

<style is:global>
	/* 필터 버튼 — 터치 타깃 44px 확보 */
	.apt-filter {
		background: #fff; border: 1px solid var(--border);
		color: var(--text); padding: 0.55em 1em; min-height: 44px; border-radius: 999px;
		font-weight: 600; font-size: .9rem; cursor: pointer;
		transition: background .15s ease, border-color .15s ease, color .15s ease;
	}
	.apt-filter:hover { background: var(--accent-soft); border-color: var(--accent-border); color: var(--accent-dim); }
	.apt-filter.is-on { background: var(--accent); border-color: var(--accent); color: #fff; }
	.leaflet-popup-content { margin: 10px 12px; line-height: 1.45; }

	.apt-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: 14px; margin: 1rem 0 1.6rem; }
	.apt-card { background: #fff; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
	.apt-card img { width: 100%; height: 128px; object-fit: cover; display: block; margin: 0; border-radius: 0; }
	.apt-card-b { padding: 11px 13px 13px; }
