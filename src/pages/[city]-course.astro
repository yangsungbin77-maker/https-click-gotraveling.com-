---
import Layout from '../layouts/BlogPost.astro';
import courseData from '../data/courses.json';

export function getStaticPaths() {
	return courseData.cities.map((city) => ({
		params: { city: city.slug },
		props: { city },
	}));
}

const { city } = Astro.props;
const courses = city.courses;
const center = city.center;
const others = courseData.cities.filter((c) => c.slug !== city.slug);

const mapsDir = (c: any) =>
	'https://www.google.com/maps/dir/' + c.stops.map((s: any) => encodeURIComponent(s.name_en)).join('/');
const mapsSearch = (s: any) =>
	'https://www.google.com/maps/search/?api=1&query=' + encodeURIComponent(s.name_en);
const totalStops = courses.reduce((n: number, c: any) => n + c.stops.length, 0);
const shortest = courses.reduce((a: any, b: any) => (a.stops.length <= b.stops.length ? a : b));
---

<Layout title={city.title} description={city.description} pubDate={new Date('July 24 2026')}>
	<p set:html={city.intro} />
	<p>
		그래서 성격이 다른 <strong>코스 {courses.length}개</strong>를 지도에 그리고, 지점
		{totalStops}곳마다 체류시간과 팁을 붙였습니다. 아래 탭으로 코스를 바꿔가며 보세요.
	</p>

	<div class="cg-box cg-tip"><span class="cg-title">💡 이렇게 쓰세요</span><p>왼쪽 목록을 누르면 지도가 그 지점으로 이동합니다. 코스마다 <b>구글 지도로 전체 열기</b> 버튼이 있어서, 스마트폰에서 누르면 그 순서 그대로 길안내가 열려요. 핀 위치는 <b>표시용 참고값</b>이라 정확한 위치는 각 지점의 지도 링크로 확인하세요.</p></div>

	<div class="crs-tabs">
		{courses.map((c: any, i: number) => (
			<button class={`crs-tab${i === 0 ? ' is-on' : ''}`} data-c={c.id} type="button">
				<span class="crs-tab-e">{c.emoji}</span>
				<span class="crs-tab-n">{c.name}</span>
				<span class="crs-tab-d">{c.duration}</span>
			</button>
		))}
	</div>

	{courses.map((c: any, i: number) => (
		<div class={`crs-head${i === 0 ? '' : ' is-hide'}`} data-head={c.id}>
			<p class="crs-tagline">{c.emoji} <strong>{c.name}</strong> — {c.tagline}</p>
			<div class="crs-meta">
				<span>⏱ {c.duration}</span>
				<span>🕘 {c.best_time}</span>
				<span>🚕 {c.transport}</span>
				<a href={mapsDir(c)} target="_blank" rel="noopener" class="crs-gmap">📍 구글 지도로 전체 열기</a>
			</div>
		</div>
	))}

	<div class="crs-app">
		<div class="crs-list" id="crs-list">
			{courses.map((c: any, ci: number) => c.stops.map((s: any, si: number) => (
				<button class={`crs-item${ci === 0 ? '' : ' is-hide'}`} data-c={c.id} data-i={si} type="button">
					<span class="crs-item-top">
						<i class="crs-num" style={`background:${c.color}`}>{s.n}</i>
						<strong>{s.name}</strong>
						{s.photo && <em class="crs-photo">📷 포토스팟</em>}
					</span>
					<span class="crs-item-m">머무는 시간 {s.stay} · {s.cost}</span>
					<span class="crs-item-t">{s.tip}</span>
				</button>
			)))}
		</div>
		<div id="crs-map" class="crs-map"></div>
	</div>

	<h2>{city.name} 코스별로 뭐가 다른가요?</h2>
	<p>같은 도시라도 목적에 따라 도는 순서가 완전히 달라집니다. {courses.length}개 코스의 성격을 한 줄로 갈라두면 이렇습니다.</p>

	<table>
		<thead><tr><th>코스</th><th>소요</th><th>이동</th><th>이런 분께</th></tr></thead>
		<tbody>
			{courses.map((c: any) => (
				<tr>
					<td><strong>{c.emoji} {c.name}</strong></td>
					<td>{c.duration}</td>
					<td>{c.transport}</td>
					<td>{c.tagline}</td>
				</tr>
			))}
		</tbody>
	</table>

	{courses.map((c: any) => (
		<>
			<h3>{c.emoji} {c.name}</h3>
			<p>{c.summary}</p>
			<ol class="crs-ol">
				{c.stops.map((s: any) => (
					<li>
						<a href={mapsSearch(s)} target="_blank" rel="noopener"><strong>{s.name}</strong></a>
						<span class="crs-ol-m"> · {s.stay} · {s.cost}</span>
						<br /><span class="crs-ol-t">{s.tip}</span>
					</li>
				))}
			</ol>
		</>
	))}

	<h2>다른 도시 코스도 지도로 보기</h2>
	<p>같은 방식으로 베트남 주요 도시 코스를 지도에 정리해뒀습니다. 도시를 묶어 다닐 계획이면 함께 보세요.</p>
	<div class="crs-city-grid">
		{others.map((o: any) => (
			<a href={`/${o.slug}-course/`} class="crs-city">
				<span class="crs-city-e">{o.emoji}</span>
				<span class="crs-city-n">{o.name}</span>
				<span class="crs-city-d">코스 {o.courses.length}개 · 지점 {o.courses.reduce((n: number, c: any) => n + c.stops.length, 0)}곳</span>
			</a>
		))}
	</div>

	<h2>자주 묻는 질문 (FAQ)</h2>
	<p><strong>Q. {city.name} 여행 코스는 어떻게 짜야 하나요?</strong> {city.wrap} 이 페이지의 코스 {courses.length}개는 성격이 겹치지 않게 나눠뒀으니, 하루에 하나씩 배정하면 동선이 꼬이지 않습니다.</p>
	<p><strong>Q. 하루에 코스 몇 개를 넣을 수 있나요?</strong> 반나절짜리 코스라면 오전·오후로 두 개까지가 현실적입니다. '하루 전체'로 표시된 코스는 이동 시간이 길어 단독으로 잡으세요. 가장 짧은 코스는 {shortest.emoji} {shortest.name}({shortest.duration})입니다.</p>
	<p><strong>Q. 코스 순서를 스마트폰으로 그대로 열 수 있나요?</strong> 각 코스의 '구글 지도로 전체 열기' 버튼을 누르면 그 순서대로 길안내가 열립니다. 개별 지점은 위 목록의 장소 이름을 눌러 지도에서 확인할 수 있어요.</p>
	<p><strong>Q. 지도의 핀 위치가 정확한가요?</strong> 핀은 코스 동선을 한눈에 보여주기 위한 표시용 참고값입니다. 실제 방문 시에는 각 지점의 지도 링크(장소 이름 검색)로 확인하는 게 정확합니다.</p>

	<p>
		여행 준비는 <a href="/vietnam-travel-checklist/">베트남 여행 준비물 체크리스트</a>,
		먹을 것은 <a href="/vietnam-street-food-noodles/">베트남 음식 총정리</a>와
		<a href="/vietnam-rice-noodle-types/">쌀국수 종류</a>,
		현지에서 쓸 말은 <a href="/travel-vietnamese-phrases/">여행 베트남어 표현</a>에 정리해뒀습니다.
		이동은 <a href="/vietnam-metro-lines/">베트남 지하철 총정리</a>를 참고하세요.
	</p>

	<p style="font-size:.86rem;color:var(--text-dim)">
		※ 지도 핀 좌표는 표시용 참고값이며 입장료·운영시간·개방 여부는 시점에 따라 변동됩니다.
		방문 전 각 지점의 공식 정보를 확인하세요. 최종 갱신 {courseData.updated}.
	</p>
</Layout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script define:vars={{ courses, center }} is:inline>
	(function init() {
		if (typeof L === 'undefined') { return setTimeout(init, 100); }
		var el = document.getElementById('crs-map');
		if (!el || el._built) { return; }
		el._built = true;

		// fadeAnimation을 켜두면 팝업이 프레임 타이밍에 기대어 나타난다.
		// 배경 탭처럼 애니메이션이 멈춘 환경에서는 opacity가 0에 멈춰 안 보이므로 끈다.
		var map = L.map('crs-map', { scrollWheelZoom: false, fadeAnimation: false }).setView(center, 13);
		L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
			maxZoom: 19, attribution: '© OpenStreetMap'
		}).addTo(map);

		var layers = {};
		var activeId = courses[0].id;

		courses.forEach(function (c) {
			var pts = c.stops.map(function (s) { return [s.lat, s.lng]; });
			var line = L.polyline(pts, { color: c.color, weight: 5, opacity: 0.8 });
			var markers = c.stops.map(function (s, i) {
				var icon = L.divIcon({
					className: 'crs-pin',
					html: '<span class="crs-pin-n" style="background:' + c.color + '">' + s.n + '</span>'
						+ '<span class="crs-pin-t">' + s.name + '</span>',
					iconSize: null, iconAnchor: [16, 16]
				});
				var m = L.marker([s.lat, s.lng], { icon: icon, riseOnHover: true });
				var q = 'https://www.google.com/maps/search/?api=1&query=' + encodeURIComponent(s.name_en);
				// autoPan을 끄지 않으면 팝업이 지도를 밀어 flyTo와 충돌한다.
				// 어차피 flyTo가 마커를 화면 중앙에 놓으므로 필요 없다.
				m.bindPopup(
					'<div style="min-width:200px">'
					+ '<b style="font-size:14px">' + s.n + '. ' + s.name + '</b>'
					+ (s.photo ? ' <span style="color:#b23a21;font-size:11px;font-weight:700">📷</span>' : '')
					+ '<hr style="margin:6px 0">'
					+ '<span style="color:#666;font-size:12px">머무는 시간 ' + s.stay + ' · ' + s.cost + '</span><br>'
					+ '<span style="color:#555;font-size:12px;line-height:1.5">' + s.tip + '</span><br>'
					+ '<a href="' + q + '" target="_blank" rel="noopener" style="font-size:12px;font-weight:700">📍 지도에서 이 장소 열기</a>'
					+ '</div>',
					{ autoPan: false }
				);
				m.on('click', function () { activate(c.id, i, false); });
				m._i = i;
				return m;
			});
			layers[c.id] = { markers: markers, line: line, pts: pts };
		});

		function show(id) {
			// 마커를 removeLayer 해도 이미 열려 있던 팝업은 지도에 남는다.
			// 코스를 바꿀 때마다 닫아주지 않으면 팝업이 계속 쌓인다.
			map.closePopup();
			Object.keys(layers).forEach(function (k) {
				var L2 = layers[k];
				if (k === id) {
					L2.line.addTo(map);
					L2.markers.forEach(function (m) { m.addTo(map); });
				} else {
					if (map.hasLayer(L2.line)) { map.removeLayer(L2.line); }
					L2.markers.forEach(function (m) {
						m.closePopup();
						if (map.hasLayer(m)) { map.removeLayer(m); }
					});
				}
			});
			activeId = id;
			map.fitBounds(L.latLngBounds(layers[id].pts).pad(0.28));
		}

		function activate(id, i, fly) {
			var items = document.querySelectorAll('.crs-item');
			items.forEach(function (it) {
				it.classList.toggle('is-active',
					it.getAttribute('data-c') === id && Number(it.getAttribute('data-i')) === i);
			});
			layers[id].markers.forEach(function (m) {
				var e = m.getElement();
				if (e) { e.classList.toggle('is-active', m._i === i); }
			});
			var mk = layers[id].markers[i];
			// 팝업은 flyTo '앞에서' 연다. 애니메이션 도중에 열면 삼켜지고,
			// 배경 탭처럼 requestAnimationFrame이 멈춘 환경에서는 moveend가
			// 아예 오지 않아 팝업이 영영 안 열린다. moveend는 보조로만 쓴다.
			mk.openPopup();
			if (fly) {
				map.flyTo(mk.getLatLng(), Math.max(map.getZoom(), 15), { duration: 0.7 });
				map.once('moveend', function () { mk.openPopup(); });
			}
			var it = document.querySelector('.crs-item.is-active');
			if (it && it.scrollIntoView) { it.scrollIntoView({ block: 'nearest', behavior: 'smooth' }); }
		}

		document.querySelectorAll('.crs-item').forEach(function (it) {
			it.addEventListener('click', function () {
				activate(it.getAttribute('data-c'), Number(it.getAttribute('data-i')), true);
			});
		});

		var tabs = document.querySelectorAll('.crs-tab');
		tabs.forEach(function (b) {
			b.addEventListener('click', function () {
				var id = b.getAttribute('data-c');
				tabs.forEach(function (x) { x.classList.remove('is-on'); });
				b.classList.add('is-on');
				document.querySelectorAll('.crs-item').forEach(function (it) {
					it.classList.toggle('is-hide', it.getAttribute('data-c') !== id);
					it.classList.remove('is-active');
				});
				document.querySelectorAll('.crs-head').forEach(function (h) {
					h.classList.toggle('is-hide', h.getAttribute('data-head') !== id);
				});
				show(id);
			});
		});

		show(activeId);
		setTimeout(function () { map.invalidateSize(); }, 200);
	})();
</script>

<style is:global>
	.crs-tabs { display: flex; gap: 8px; flex-wrap: wrap; margin: 1rem 0 .8rem; }
	.crs-tab {
		flex: 1 1 140px; background: #fff; border: 1px solid var(--border);
		color: var(--text); padding: .6em .8em; min-height: 44px; border-radius: 12px;
		cursor: pointer; font: inherit; text-align: left; line-height: 1.25;
		transition: background .15s ease, border-color .15s ease;
	}
	.crs-tab:hover { background: var(--accent-soft); border-color: var(--accent-border); }
	.crs-tab.is-on { background: var(--accent); border-color: var(--accent); color: #fff; }
	.crs-tab-e { font-size: 1.05rem; margin-right: 4px; }
	.crs-tab-n { font-weight: 700; font-size: .92rem; }
	.crs-tab-d { display: block; font-size: .74rem; opacity: .75; margin-top: 2px; }

	.crs-head.is-hide { display: none; }
	.crs-tagline { margin: .2rem 0 .5rem; font-size: .98rem; }
	.crs-meta { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; margin-bottom: .6rem; }
	.crs-meta > span {
		font-size: .8rem; color: var(--text-muted);
		background: var(--bg-elev-2); padding: 4px 10px; border-radius: 999px;
	}
	.crs-gmap {
		margin-left: auto; font-size: .82rem; font-weight: 700;
		background: var(--accent-soft); color: var(--accent-dim);
		padding: 7px 12px; border-radius: 999px; text-decoration: none;
		border: 1px solid var(--accent-border);
	}
	.crs-gmap:hover { background: var(--accent); color: #fff; }

	.crs-app {
		display: grid; grid-template-columns: 320px 1fr; gap: 0;
		height: 600px; margin: .4rem 0 1.4rem;
		border: 1px solid var(--border); border-radius: 14px; overflow: hidden;
		background: #fff;
		width: min(1120px, calc(100vw - 32px));
		position: relative; left: 50%; transform: translateX(-50%);
	}
	.crs-list { overflow-y: auto; border-right: 1px solid var(--border); background: var(--bg); }
	.crs-item {
		display: block; width: 100%; text-align: left; cursor: pointer;
		background: #fff; border: 0; border-bottom: 1px solid var(--border);
		padding: 11px 13px; font: inherit; color: var(--text);
		transition: background .12s ease;
	}
	.crs-item.is-hide { display: none; }
	.crs-item:hover { background: var(--accent-soft); }
	.crs-item.is-active { background: var(--accent-soft); box-shadow: inset 3px 0 0 var(--accent); }
	.crs-item-top { display: flex; align-items: center; gap: 7px; font-size: .94rem; }
	.crs-num {
		width: 21px; height: 21px; border-radius: 50%; flex: none; color: #fff;
		display: flex; align-items: center; justify-content: center;
		font-size: 12px; font-weight: 800; font-style: normal;
	}
	.crs-photo {
		font-style: normal; font-size: .67rem; font-weight: 700; margin-left: auto;
		color: #b23a21; background: rgba(178, 58, 33, .1); padding: 2px 6px; border-radius: 5px;
	}
	.crs-item-m { display: block; font-size: .76rem; color: var(--text-dim); margin: 4px 0 5px; }
	.crs-item-t { display: block; font-size: .8rem; color: var(--text-muted); line-height: 1.5; }
	.crs-map { height: 100%; width: 100%; z-index: 0; }

	.crs-pin { display: flex; align-items: center; gap: 5px; white-space: nowrap; cursor: pointer; }
	.crs-pin-n {
		width: 27px; height: 27px; border-radius: 50%; color: #fff; flex: none;
		display: flex; align-items: center; justify-content: center;
		font-size: 14px; font-weight: 800; border: 2px solid #fff;
		box-shadow: 0 1px 5px rgba(0, 0, 0, .4);
		transition: transform .12s ease;
	}
	.crs-pin-t {
		background: rgba(255, 255, 255, .93); border-radius: 6px; padding: 2px 7px;
		font-size: 11.5px; font-weight: 700; color: var(--text);
		box-shadow: 0 1px 4px rgba(35, 50, 41, .2);
	}
	.crs-pin:hover .crs-pin-n { transform: scale(1.12); }
	.crs-pin.is-active .crs-pin-n { transform: scale(1.2); box-shadow: 0 0 0 4px rgba(22, 101, 52, .28); }

	.crs-ol { padding-left: 1.2rem; }
	.crs-ol li { margin-bottom: .7rem; }
	.crs-ol-m { font-size: .84rem; color: var(--text-dim); }
	.crs-ol-t { font-size: .88rem; color: var(--text-muted); line-height: 1.6; }

	/* 다른 도시 카드 */
	.crs-city-grid {
		display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
		gap: 10px; margin: 1rem 0 1.6rem;
	}
	.crs-city {
		display: block; text-decoration: none; background: #fff;
		border: 1px solid var(--border); border-radius: 12px; padding: 13px;
		transition: background .15s ease, border-color .15s ease;
	}
	.crs-city:hover { background: var(--accent-soft); border-color: var(--accent-border); }
	.crs-city-e { font-size: 1.5rem; display: block; }
	.crs-city-n { display: block; font-weight: 700; font-size: 1rem; color: var(--text); margin-top: 4px; }
	.crs-city-d { display: block; font-size: .76rem; color: var(--text-dim); margin-top: 2px; }

	@media (max-width: 760px) {
		.crs-app { grid-template-columns: 1fr; grid-template-rows: 46vh 1fr; height: auto; }
		.crs-map { order: -1; height: 46vh; }
		.crs-list { border-right: 0; border-top: 1px solid var(--border); max-height: 340px; }
		.crs-gmap { margin-left: 0; width: 100%; text-align: center; }
	}
</style>
